{
  "family": "payment-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::670173257019:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "payment-api",
      "image": "670173257019.dkr.ecr.ap-southeast-2.amazonaws.com/payment-app:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "hostPort": 3000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "DB_NAME", "value": "payments" },
        { "name": "DB_PORT", "value": "5432" }
      ],
      "secrets": [
        {
          "name": "DB_HOST",
          "valueFrom": "arn:aws:secretsmanager:ap-southeast-2:670173257019:secret:/payment-app/db-credentials-sYYYHQ::DB_HOST::"
        },
        {
          "name": "DB_USER",
          "valueFrom": "arn:aws:secretsmanager:ap-southeast-2:670173257019:secret:/payment-app/db-credentials-sYYYHQ::DB_USER::"
        },
        {
          "name": "DB_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:ap-southeast-2:670173257019:secret:/payment-app/db-credentials-sYYYHQ::DB_PASSWORD::"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/payment-task",
          "awslogs-region": "ap-southeast-2",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      }
    }
  ]
}